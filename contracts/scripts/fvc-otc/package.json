{
  "name": "fvc-otc",
  "version": "1.0.0",
  "description": "FVC OTC Mint Terminal",
  "main": "dist/index.js",
  "bin": {
    "fvc-otc": "dist/index.js"
  },
  "scripts": {
    "build": "esbuild index.ts --bundle --platform=node --target=node18 --outfile=dist/index.js --external:bufferutil --external:utf-8-validate",
    "package": "npm run build && pkg dist/index.js --targets node18-linux-x64 --output fvc-otc",
    "install-global": "npm run build && npm link"
  },
  "dependencies": {
    "ethers": "^6.9.0",
    "@safe-global/protocol-kit": "^4.0.0",
    "@safe-global/api-kit": "^2.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "pkg": "^5.8.1",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
